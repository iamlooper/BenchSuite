    <!-- About Screen -->
    <string name="about_title">About BenchSuite</string>
    <string name="about_hero_headline">Raw performance truth, well visualized.</string>
    <string name="about_hero_body">BenchSuite exercises real kernel and OS primitives, not synthetic workloads, to deliver accurate measurements. Results stay on your device unless you choose to share them.</string>
    <string name="about_section_measures">What BenchSuite measures</string>
    <string name="about_measures_body">Tests cover CPU, memory, scheduler, IPC, storage I/O, timers, and network. Each exercises real OS primitives for honest, reproducible scores.</string>
    <string name="about_section_privacy">Privacy and uploads</string>
    <string name="about_privacy_body">All results are stored locally. Publishing to the leaderboard is optional, anonymous, and always requires your confirmation.</string>
